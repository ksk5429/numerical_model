# Op^3 repo .gitignore
# Strategy: track the framework source and benchmarks. Exclude
# build artifacts, large raw data, virtual environments, and cache.

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
.env
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# OS/IDE
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
~$*

# OpenFAST runtime outputs
*.out
*.outb
*.ech
*.sum
*.fmt

# OptumGX large raw data (only the small result CSVs are tracked)
data/optumgx_outputs/raw_plates/
data/optumgx_outputs/*.xlsx

# Large intermediate files (commit only the summary CSVs)
*.h5
*.hdf5
*.npz

# Editor files
*.bak
*.tmp
*.log

# Git trash
*.orig
*.rej

# OpenFAST binary (52 MB, fetched by tools/openfast/install.ps1)
tools/openfast/openfast_x64.exe
tools/openfast/*.exe
tools/openfast/*.dll

# Large shared data directories (bootstrap via r-test clone)
tools/r-test_v5/
ref_site_a/5MW_Baseline/

# Binary OpenFAST time-series output
validation/openfast_runs/
validation/dlc11_partial/
validation/dlc61_parked/
ref_site_a/openfast_deck_v5/*.outb
ref_site_a/openfast_deck_v5/*.out


# OpenFAST generated simulation outputs (not source)
ref_site_a/openfast_deck_v5/*.sum
ref_site_a/openfast_deck_v5/*.sum.yaml
ref_site_a/openfast_deck_v5/*.AD.sum
ref_site_a/openfast_deck_v5/*.ED.sum
ref_site_a/openfast_deck_v5/*.SD.sum.yaml
ref_site_a/openfast_deck_v5/*.SrvD.sum
ref_site_a/openfast_deck_v5/*.UA.sum
ref_site_a/openfast_deck_v5/*.out
ref_site_a/openfast_deck_v5/*.outb
ref_site_a/openfast_deck_v5/*.ech

# Extracted paper text (local reference only; copyrighted)
tools/papers/

# Validation report timestamps (regenerate via release script)
validation/release_report/

# Sphinx build output (regenerated by CI)
docs/sphinx/_build/

